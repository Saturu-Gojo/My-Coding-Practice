#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    void bfs(int sr, int sc, int color,vector<vector<int>>& image){
        int ini = image[sr][sc];
        queue<pair<int,int>> q;
        q.push({sr,sc});
        int n=image.size();
        int m = image[0].size();
        vector<vector<int>> vis(n,vector<int>(m,0));
        vis[sr][sc]=1;
        image[sr][sc]=color;

        while(!q.empty()){
            int nsr = q.front().first;
            int nsc = q.front().second;
            q.pop();

            vector<int> dr = {-1,0,1,0};
            vector<int> dc = {0,-1,0,1};
            for(int i=0; i<4; i++){
                int ns = nsr+dr[i];
                int nc = nsc + dc[i];
                if(ns>=0 && nc>=0 && ns<n && nc<m && !vis[ns][nc] && image[ns][nc]==ini){
                    q.push({ns,nc});
                    vis[ns][nc]=1;
                    image[ns][nc]=color;
                }
            }
        }
    }


    vector<vector<int>> floodFill(vector<vector<int>>& image, int sr, int sc, int color) {
        bfs(sr, sc, color,image);
        return image;

        
    }
};